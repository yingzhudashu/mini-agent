{
  "name": "mini-agent",
  "version": "4.5.0",
  "description": "A minimal LLM agent with two-phase planning, skill system, self-optimization, and Feishu integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/cli.ts",
    "feishu": "tsx src/feishu-cli.ts",
    "test": "tsx tests/test.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "pkg:win": "pkg . -t node20-win-x64 -o dist/mini-agent-win.exe",
    "pkg:mac": "pkg . -t node20-macos-x64,node20-macos-arm64 -o dist/mini-agent-macos",
    "pkg:linux": "pkg . -t node20-linux-x64,node20-linux-arm64 -o dist/mini-agent-linux",
    "pkg:all": "npm run pkg:win && npm run pkg:mac && npm run pkg:linux"
  },
  "bin": "dist/src/cli.js",
  "keywords": [
    "llm",
    "agent",
    "react",
    "tool-calling",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "dotenv": "^16.4.7",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      ".env.example"
    ],
    "outputPath": "dist"
  }
}
