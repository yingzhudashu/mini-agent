# Mini Agent 环境变量配置
# 复制此文件为 .env 并填入真实值
# ⚠️ 不要将 .env 提交到 Git

# ── API 配置 ──

# API 端点
# DashScope 百炼: https://coding.dashscope.aliyuncs.com/v1
# OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# API 密钥（从模型服务商控制台获取）
OPENAI_API_KEY=your-api-key-here

# 模型名称
# 推荐: qwen3.6-plus (DashScope), gpt-4o-mini (OpenAI)
OPENAI_MODEL=qwen3.6-plus

# ── Agent 行为配置（v4.5+） ──

# 最大对话轮数（默认 20）
# AGENT_MAX_TURNS=20

# 循环检测警告阈值（默认 8）
# LOOP_WARNING_THRESHOLD=8

# 循环检测终止阈值（默认 12）
# LOOP_CRITICAL_THRESHOLD=12

# 工具超时秒数（默认 60）
# AGENT_TOOL_TIMEOUT=60

# HTTP 超时秒数（默认 120）
# AGENT_HTTP_TIMEOUT=120

# 调试模式（默认 false）
# AGENT_DEBUG=false

# ── 飞书集成（v4.5+） ──

# 飞书 App ID（从飞书开放平台获取）
# FEISHU_APP_ID=cli_xxxxxxxxxx

# 飞书 App Secret
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# Webhook 服务器端口（默认 9800）
# FEISHU_PORT=9800

# ── 可选配置 ──

# 工作空间根目录（默认当前工作目录）
# MINI_AGENT_WORKSPACE=D:\AIhub\mini-agent

# 系统时区（默认 Asia/Shanghai）
# TZ=Asia/Shanghai
