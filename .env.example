# Mini Agent 环境变量配置
# 复制此文件为 .env 并填入真实值
# ⚠️ 不要将 .env 提交到 Git

# ── API 配置 ──

# API 端点
# DashScope 百炼: https://coding.dashscope.aliyuncs.com/v1
# OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# API 密钥（从模型服务商控制台获取）
OPENAI_API_KEY=your-api-key-here

# 模型名称
# 推荐: qwen3.6-plus (DashScope), gpt-4o-mini (OpenAI)
OPENAI_MODEL=qwen3.6-plus

# ── 可选配置 ──

# 工作空间根目录（默认当前工作目录）
# MINI_AGENT_WORKSPACE=D:\AIhub\mini-agent

# 系统时区（默认 Asia/Shanghai）
# TZ=Asia/Shanghai
